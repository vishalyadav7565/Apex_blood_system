# Production Django Environment Variables
DEBUG=False
SECRET_KEY=generate-a-strong-secret-key-here
ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com,YOUR_EC2_PUBLIC_IP
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com,https://your-netlify-subdomain.netlify.app
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com,https://your-netlify-subdomain.netlify.app

# Database Configuration
DB_NAME=blood_db
DB_USER=postgres
DB_PASSWORD=your_secure_db_password
DB_HOST=db
DB_PORT=5432

# Redis / Celery Configuration
REDIS_URL=redis://redis:6379/0

# Firebase Credentials
FIREBASE_CREDENTIALS=/app/firebase-service-account.json
